{
  "name": "wp-interior-backend",
  "version": "1.0.0",
  "description": "WP Interior Studio - Backend API Server",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test src/tests",
    "seed": "node src/seed.js",
    "docker:build": "docker build -t wp-interior-backend .",
    "docker:run": "docker run -p 4000:4000 wp-interior-backend"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "cors-anywhere": "^0.4.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "twilio": "^4.19.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
