# Server
PORT=4000
NODE_ENV=production
JWT_SECRET=wp-interior-super-secret-key-change-in-production
CLIENT_ORIGIN=http://localhost:3000

# Database (MongoDB) - leave empty to use in-memory store
MONGODB_URI=
USE_MEMORY_STORE=true

# WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_ALERT_PHONE=+923001234567

# OpenAI / LLM Agent (optional)
OPENAI_API_KEY=
LLM_AGENT_ENABLED=false
LLM_AGENT_MODEL=gpt-4o-mini

# Email (for LLM agent notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
